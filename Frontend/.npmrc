# .npmrc - NPM configuration for Starbucks Egypt React Clone

# Prevent npm from automatically creating package-lock.json for global installs
global = false

# Use strict peer dependencies (helps catch issues early)
strict-peer-deps = true

# Legacy peer deps workaround for vite-plugin-pwa
legacy-peer-deps = true

# Optimize network requests
maxsockets = 50

# Use smaller node_modules with symbolic links when possible
prefer-offline = false

# Ensure clean installs in CI
package-lock = true

# Use the default npm registry
registry = https://registry.npmjs.org/

# Disable package-lock.json auto-generation (we commit it)
# package-lock = false