{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=starbucks_dev.db",
    "Redis": ""
  },
  "Jwt": {
    "ExpiryInHours": 24
  },
  "Cors": {
    "AllowedOrigins": "http://localhost:3000,http://localhost:5173,http://localhost:5000"
  },
  "Logging": {
    "EnableSensitiveDataLogging": true,
    "EnableDetailedErrors": true
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "System": "Information"
      }
    }
  },
  "IpRateLimiting": {
    "GeneralRules": [
      {
        "Endpoint": "*",
        "Period": "1m",
        "Limit": 1000
      },
      {
        "Endpoint": "*",
        "Period": "1h",
        "Limit": 10000
      }
    ]
  }
}