{
  "ConnectionStrings": {
    "DefaultConnection": "@Microsoft.KeyVault(SecretUri=https://your-keyvault.vault.azure.net/secrets/db-connection-string/)",
    "Redis": "@Microsoft.KeyVault(SecretUri=https://your-keyvault.vault.azure.net/secrets/redis-connection-string/)"
  },
  "KeyVault": {
    "Url": "https://your-keyvault.vault.azure.net/"
  },
  "Jwt": {
    "ExpiryInHours": 1
  },
  "Cors": {
    "AllowedOrigins": "https://starbucks.eg"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "StarbucksEgypt": "Information"
      }
    }
  },
  "IpRateLimiting": {
    "GeneralRules": [
      {
        "Endpoint": "*",
        "Period": "1m",
        "Limit": 60
      },
      {
        "Endpoint": "*",
        "Period": "1h",
        "Limit": 500
      },
      {
        "Endpoint": "POST:/api/auth/login",
        "Period": "1m",
        "Limit": 3
      },
      {
        "Endpoint": "POST:/api/auth/register",
        "Period": "1m",
        "Limit": 2
      },
      {
        "Endpoint": "POST:/api/auth/refresh",
        "Period": "1m",
        "Limit": 5
      }
    ]
  }
}