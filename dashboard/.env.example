# Environment variables for Netlify deployment
# Copy this file to .env.production and update with actual values
# Or set these in Netlify Dashboard > Site settings > Environment variables

# API Configuration
VITE_API_URL=https://your-backend-api.com/api
VITE_API_VERSION=v1

# Application Settings
VITE_APP_NAME=Starbucks Dashboard
VITE_ENABLE_ANALYTICS=true
VITE_LOG_LEVEL=error

# Optional: Add authentication keys if needed
# VITE_AUTH_DOMAIN=your-auth-domain.com
# VITE_AUTH_CLIENT_ID=your-client-id
