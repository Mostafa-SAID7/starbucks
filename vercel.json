{
  "buildCommand": "npm --prefix Frontend run build",
  "installCommand": "npm --prefix Frontend install",
  "outputDirectory": "Frontend/dist",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
